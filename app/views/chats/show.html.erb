<% content_for :title, "#{@result.type.name}に質問する" %>

<h1><%= @result.type.name %>に質問する</h1>

<%# JS から複製するためのテンプレート画像（非表示） %>
<% if @result.type.image_path.present? %>
  <%= image_tag @result.type.image_path,
      id: "chat-avatar-template",
      class: "chat-avatar-img",
      width: 90,
      alt: @result.type.name,
      style: "display:none" %>
<% end %>

<section class="chat-section">
  <div id="chat-messages" class="chat-messages">
    <div class="chat-row chat-row--left">
      <% if @result.type.image_path.present? %>
        <%= image_tag @result.type.image_path, class: "chat-avatar-img", width: 90, alt: @result.type.name %>
      <% end %>
      <div class="speech-bubble speech-bubble--left">
        <p>こんにちは！<%= @result.type.name %>だよ！なんでも聞いてね！</p>
      </div>
    </div>
  </div>

  <%# data-turbo="false" で Turbo Drive を介さず JS の fetch で送信する %>
  <%= form_with url: result_chat_path(@result), method: :post, id: "chat-form",
      data: { turbo: false } do |f| %>
    <div class="chat-form">
      <%= f.text_field :question,
          placeholder: "#{@result.type.name}についての質問を入力してください...",
          class: "chat-input",
          id: "chat-question-input",
          autocomplete: "off" %>
      <%= f.submit "送信", class: "chat-submit", id: "chat-submit" %>
    </div>
  <% end %>
</section>

<div style="margin-top: 2rem;">
  <%= link_to "結果に戻る", result_path(@result), class: "btn btn-secondary" %>
</div>

<script>
  (function() {
    var form    = document.getElementById("chat-form");
    var input   = document.getElementById("chat-question-input");
    var submit  = document.getElementById("chat-submit");
    var messages = document.getElementById("chat-messages");
    var template = document.getElementById("chat-avatar-template");
    var csrfToken = (document.querySelector('meta[name="csrf-token"]') || {}).content || "";

    function makeAvatarImg() {
      if (!template) return null;
      var img = template.cloneNode();
      img.removeAttribute("id");
      img.style.display = "";
      return img;
    }

    function appendRow(side, contentEl) {
      var row = document.createElement("div");
      row.className = "chat-row chat-row--" + side;
      if (side === "left") {
        var avatar = makeAvatarImg();
        if (avatar) row.appendChild(avatar);
      }
      row.appendChild(contentEl);
      messages.appendChild(row);
      messages.scrollTop = messages.scrollHeight;
      return row;
    }

    function makeBubble(side, text) {
      var bubble = document.createElement("div");
      bubble.className = "speech-bubble speech-bubble--" + side;
      var p = document.createElement("p");
      p.textContent = text;
      bubble.appendChild(p);
      return bubble;
    }

    form.addEventListener("submit", async function(e) {
      e.preventDefault();

      var question = input.value.trim();
      if (!question) return;

      // ① ユーザーの質問を右吹き出しで即時表示
      appendRow("right", makeBubble("right", question));

      // ② 「回答を考え中・・・」を爬虫類画像の右に表示
      var loadingBubble = makeBubble("left", "回答を考え中・・・");
      loadingBubble.classList.add("chat-loading");
      var loadingRow = appendRow("left", loadingBubble);
      loadingRow.id = "chat-loading";

      input.value = "";
      submit.disabled = true;

      try {
        // ③ Turbo を介さず fetch で送信（プログレスバーが出ない）
        var formData = new FormData(form);
        formData.set("question", question);

        var res = await fetch(form.action, {
          method: "POST",
          body: formData,
          headers: {
            "Accept": "text/vnd.turbo-stream.html",
            "X-CSRF-Token": csrfToken
          }
        });

        var html = await res.text();
        // ④ turbo_stream レスポンスを適用（「考え中」除去 → 回答追加）
        Turbo.renderStreamMessage(html);
        messages.scrollTop = messages.scrollHeight;
      } catch (_) {
        loadingRow.remove();
        appendRow("left", makeBubble("left", "エラーが発生したよ。もう一度試してみてね。"));
      } finally {
        submit.disabled = false;
      }
    });
  })();
</script>
