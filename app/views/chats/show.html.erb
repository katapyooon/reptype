<% content_for :title, "#{@result.type.name}に質問する" %>

<h1><%= @result.type.name %>に質問する</h1>

<section class="chat-section">
  <div id="chat-messages" class="chat-messages">
    <div class="chat-row chat-row--left">
      <% if @result.type.image_path.present? %>
        <%= image_tag @result.type.image_path, class: "chat-avatar-img", width: 60, alt: @result.type.name %>
      <% end %>
      <div class="speech-bubble speech-bubble--left">
        <p>こんにちは！<%= @result.type.name %>だよ！なんでも聞いてね！</p>
      </div>
    </div>
  </div>

  <%= form_with url: result_chat_path(@result), method: :post, id: "chat-form" do |f| %>
    <div class="chat-form">
      <%= f.text_field :question,
          placeholder: "#{@result.type.name}についての質問を入力してください...",
          class: "chat-input",
          id: "chat-question-input",
          autocomplete: "off" %>
      <%= f.submit "送信", class: "chat-submit", data: { turbo_submits_with: "送信中..." } %>
    </div>
  <% end %>
</section>

<div style="margin-top: 2rem;">
  <%= link_to "結果に戻る", result_path(@result), class: "btn btn-secondary" %>
</div>

<script>
  (function() {
    var avatarImgHtml = <%= raw @result.type.image_path.present? ?
      "\"#{image_tag(@result.type.image_path, class: 'chat-avatar-img', width: 60, alt: @result.type.name).gsub('"', '\\"')}\"" :
      "''" %>;

    document.getElementById("chat-form").addEventListener("submit", function(e) {
      var input = document.getElementById("chat-question-input");
      var question = input.value.trim();
      if (!question) return;

      var messages = document.getElementById("chat-messages");

      // ユーザーメッセージを即時表示
      var userRow = document.createElement("div");
      userRow.className = "chat-row chat-row--right";
      var escaped = document.createTextNode(question);
      var p = document.createElement("p");
      p.appendChild(escaped);
      var bubble = document.createElement("div");
      bubble.className = "speech-bubble speech-bubble--right";
      bubble.appendChild(p);
      userRow.appendChild(bubble);
      messages.appendChild(userRow);

      // 「考え中...」バブルを表示（turbo_stream が来たら除去）
      var loadingRow = document.createElement("div");
      loadingRow.className = "chat-row chat-row--left";
      loadingRow.id = "chat-loading";
      loadingRow.innerHTML = avatarImgHtml + '<div class="speech-bubble speech-bubble--left chat-loading"><p>考え中...</p></div>';
      messages.appendChild(loadingRow);

      messages.scrollTop = messages.scrollHeight;
      input.value = "";
    });

    document.addEventListener("turbo:stream-render", function() {
      var messages = document.getElementById("chat-messages");
      if (messages) messages.scrollTop = messages.scrollHeight;
    });
  })();
</script>
