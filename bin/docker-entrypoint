#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# Run db:migrate on every deploy (db:prepare = create if not exists + migrate)
# WARNING: db:create と db:seed は初回のみ必要なため、ECSの別タスクとして実行すること
./bin/rails db:prepare

exec "${@}"
